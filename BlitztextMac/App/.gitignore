# =============================================================================
# Blitztext .gitignore
# =============================================================================

# Xcode Build
build/
DerivedData/
*.moved-aside

# Xcode User Data
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
xcuserdata/

# Xcode Shared Data (optional, manche Teams committen das)
*.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/

# Xcode Playgrounds
timeline.xctimeline
playground.xcworkspace

# App Bundles & Archives
*.app
*.ipa
*.dSYM.zip
*.dSYM

# macOS System Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Swift Package Manager
.build/
Packages/
Package.resolved

# CocoaPods (falls verwendet)
Pods/

# Sensitive Data - NIEMALS committen!
*.key
*.pem
*.p12
*.mobileprovision
*.provisionprofile

# WhisperKit / ML Modelle (zu groß für Git)
*.mlmodelc/
*.mlpackage/
models/

# Temporary Files
*.swp
*.swo
*~
\#*\#

# Crashlytics
crashlytics-build.properties
crashlytics.properties
fabric.properties
